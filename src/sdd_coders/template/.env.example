# Copy to .env and adjust. NEVER commit real secrets.

# --- Backend ---------------------------------------------------------------
APP_ENVIRONMENT=development
# App connects as the least-privilege role (no BYPASSRLS).
APP_DATABASE_URL=postgresql+asyncpg://app_user:app_pass@db:5432/app
# Generate a strong value in production: `openssl rand -hex 32`
APP_JWT_SECRET=change-me-in-production-min-32-bytes-long-0123
APP_CORS_ORIGINS=["http://localhost:3000"]

# Migrations run as the database owner.
ALEMBIC_DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/app

# --- Frontend --------------------------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:8000

# --- Postgres (docker-compose) ---------------------------------------------
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=app
