# Copy this file to terraform.tfvars and fill in your values.
# NEVER commit terraform.tfvars — it is gitignored.

app_name = "myapp"
domain   = "example.com"

# The VPS — create it manually in hPanel and paste its public IP here.
vps_ip = "203.0.113.10"

# Optional fully-automated VPS provisioning via the Hostinger API. Off by
# default; the supported path is a manually-created VPS (vps_ip above).
manage_vps         = false
hostinger_api_key  = "" # only needed when manage_vps = true
hostinger_vps_plan = "KVM 2"
hostinger_region   = "eu-west-1"

# Cloudflare — https://dash.cloudflare.com/profile/api-tokens
cloudflare_api_token  = "CHANGE_ME"
cloudflare_zone_id    = "CHANGE_ME"
turnstile_secret_key  = "CHANGE_ME"

# Coolify — https://coolify.yourdomain.com/settings/api-tokens
coolify_url   = "https://coolify.example.com"
coolify_token = "CHANGE_ME"
