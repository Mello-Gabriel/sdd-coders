# Copy this file to .env and fill in real values for local development.
# NEVER commit .env or any file with real secrets.
# Production secrets live in Coolify and GitHub Secrets only.

# ── Postgres ───────────────────────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=app

APP_DATABASE_URL=postgresql+asyncpg://app_user:CHANGE_ME@localhost:55432/app
ALEMBIC_DATABASE_URL=postgresql+asyncpg://postgres:CHANGE_ME@localhost:55432/app

# ── Redis ──────────────────────────────────────────────────────────────────
REDIS_PASSWORD=CHANGE_ME
APP_REDIS_URL=redis://:CHANGE_ME@localhost:6379/0

# ── JWT ────────────────────────────────────────────────────────────────────
APP_JWT_SECRET=CHANGE_ME_use_at_least_32_random_chars

# ── Email ──────────────────────────────────────────────────────────────────
APP_EMAIL_PROVIDER=resend          # memory | resend | smtp
APP_RESEND_API_KEY=CHANGE_ME
APP_FRONTEND_URL=https://example.com

# ── Turnstile (Cloudflare) ─────────────────────────────────────────────────
APP_TURNSTILE_ENABLED=true
APP_TURNSTILE_SECRET_KEY=CHANGE_ME

NEXT_PUBLIC_TURNSTILE_SITE_KEY=CHANGE_ME

# ── Google Analytics ───────────────────────────────────────────────────────
NEXT_PUBLIC_GA_ID=G-CHANGE_ME

# ── Frontend ───────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=https://api.example.com

# ── Terraform / Infra ──────────────────────────────────────────────────────
HOSTINGER_API_KEY=CHANGE_ME
CLOUDFLARE_API_TOKEN=CHANGE_ME
CLOUDFLARE_ZONE_ID=CHANGE_ME
COOLIFY_TOKEN=CHANGE_ME
COOLIFY_URL=https://coolify.example.com
